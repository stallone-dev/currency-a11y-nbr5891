# Configuração de finais de linha (garantindo LF para Deno)
* text=auto eol=lf

# Arquivos TypeScript e JSON
*.ts text
*.json text
*.jsonc text
*.md text

# Assets e Fontes (Tratar como binários para evitar corrupção)
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.js text
*.css text

# Shell scripts
*.sh text eol=lf
